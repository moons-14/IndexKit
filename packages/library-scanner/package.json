{
  "name": "@indexkit/library-scanner",
  "version": "0.0.1",
  "description": "Fast, memory-efficient library scanner for CBZ, CBR, PDF, EPUB, and image directories",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "tsc --project tsconfig.bench.json && node dist-bench/bench/scan-bench.js",
    "bench:extract": "tsc --project tsconfig.bench.json && node dist-bench/bench/extract-bench.js"
  },
  "dependencies": {
    "pdfjs-dist": "^4.0.0",
    "sharp": "^0.33.0",
    "yauzl-promise": "^4.0.0",
    "node-unrar-js": "^2.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@indexkit/cbz-fixture": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
