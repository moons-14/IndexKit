{
  "name": "@indexkit/cbz-fixture",
  "version": "0.0.1",
  "description": "Generate test CBZ fixture files with randomized images and ComicInfo.xml metadata",
  "private": true,
  "type": "module",
  "bin": {
    "cbz-fixture": "./dist/cli.js"
  },
  "scripts": {
    "generate": "tsx src/cli.ts",
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fflate": "^0.8.2",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
